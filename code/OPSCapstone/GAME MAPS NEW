void showEndScreen() {
  lcd1.clear();

  lcd1.setCursor(0, 0);
  lcd1.print("   YOU WIN!   ");

  lcd1.setCursor(0, 1);
  lcd1.print(" Press Select ");

  // wait for restart
  if (digitalRead(btnSelect) == HIGH) {
    resetGame();
    delay(300);
  }
}
void resetGame() {
  gameStarted = false;
  gameOver = false;

  offset = 0;
  playerX = 2;
  playerY = 0;

  drawMenu(lcd1);
}

